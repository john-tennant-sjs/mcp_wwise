        "oneOf": [
          {
            "type": "object",
            "required": ["state"],
            "properties": {
              "state": {"type": "string"}
            }
          },
          {"type": "null"}
        ]
      }
    },
    "additionalProperties": false
  },
  "mock_response": {"success": true, "data": {"state": "stopped"}, "error": null}
}
